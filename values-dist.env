# Xoro Picture Manager Configuration
# Usage: ./xoro_picture_manager.sh values.env /path/to/pictures

XORO_HOST="xoro"
XORO_IP="192.168.0.100"

# Optional settings (uncomment to override defaults)
# XORO_PORT="2121"                    # FTP port
# MAX_PICS="100"                      # Pictures per upload
# COVERAGE_PERCENTAGE="80"            # % of collection to show before repeating (1-100)
# PREFIX="XPM"                        # Uploaded filename prefix
# STORAGE="internal"                  # "internal" or "sd"
# UPLOAD_RETRIES="10"                 # Max upload failures before abort
# STATE_FILE="/var/tmp/xoro_pictures.state"  # Path to state tracking file
